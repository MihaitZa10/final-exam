datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/app/server/generated"
}

model Post { 
  id         Int        @id @default(autoincrement()) 
  createdAt  DateTime   @default(now()) 
  updatedAt  DateTime   @updatedAt
  title      String
  text String
  pinned  Boolean    @default(false) 
  
} 